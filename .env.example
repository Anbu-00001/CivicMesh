# Required — NVIDIA NIM key used by byllm to call meta/llama-3.1-8b-instruct.
# Get a free key at https://build.nvidia.com/.
NVIDIA_NIM_API_KEY=

# Optional — fallback provider used if NIM is unreachable. Leave blank to disable.
FEATHERLESS_API_KEY=

# Optional — server bindings. Defaults shown.
# JAC_SCALE_HOST=127.0.0.1
# JAC_SCALE_PORT=8001
# JAC_CLIENT_PORT=8000

# Optional — log verbosity: debug | info | warn | error.
# CIVICMESH_LOG_LEVEL=info
